{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022"],
    "types": ["bun", "node"],
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@vaultmind/auth-shared": ["./packages/auth-shared/src/index.ts"]
    }
  },
  "include": [
    "packages/**/*.ts",
    "services/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
